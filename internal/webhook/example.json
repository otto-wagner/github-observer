{
  "webhooks":  [
    {
      "payloadUrl": "https://localhost:8443/listen/workflow",
      "contentType": "json",
      "insecureSsl": "0",
      "events": [
        "workflow_run"
      ]
    },
    {
      "payloadUrl": "https://localhost:8443/listen/pullrequest",
      "contentType": "json",
      "insecureSsl": "0",
      "events": [
        "pull_request"
      ]
    },
    {
      "payloadUrl": "https://localhost:8443/listen/pullrequest/review",
      "contentType": "json",
      "insecureSsl": "0",
      "events": [
        "pull_request_review"
      ]
    }
  ],
  "repositories": [
    "otto-wagner/github-observer@main"
  ]
}
